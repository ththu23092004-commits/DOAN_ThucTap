@model VeSuKienWeb.Models.BanToChuc.DanhSachVeThamGiaBtcVM

@{
    Layout = "~/Views/Shared/_LayoutBanToChuc.cshtml";
    ViewData["Title"] = "Danh sách vé / tham gia";

    // ✅ Chỉ lấy vé đã đặt thật: Đã thanh toán hoặc đã check-in
    var dsDaDat = (Model.DanhSach ?? new List<VeSuKienWeb.Models.BanToChuc.DanhSachVeThamGiaItemBtcVM>())
        .Where(x => x.TrangThaiVe == "DaThanhToan" || x.TrangThaiVe == "DaCheckIn")
        .ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Danh sách vé đã đặt</h2>
        <div class="text-muted small">
            Sự kiện: <strong>@Model.TenSuKien</strong>
        </div>
    </div>
    <a asp-action="ChiTiet" asp-route-id="@Model.SuKienId" class="btn btn-outline-secondary">
        &laquo; Quay lại chi tiết sự kiện
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        @if (dsDaDat.Any())
        {
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="text-muted small">
                    Tổng vé đã đặt: <strong>@dsDaDat.Count</strong>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Mã vé</th>
                            <th>Khách hàng</th>
                            <th>Email</th>
                            <th>Loại vé</th>
                            <th>Trạng thái vé</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in dsDaDat)
                        {
                            <tr>
                                <td class="fw-semibold">@item.MaVe</td>
                                <td>@item.HoTenKhach</td>
                                <td class="text-muted">@item.EmailKhach</td>
                                <td>@item.TenLoaiVe</td>
                                <td>
                                    @if (item.TrangThaiVe == "DaCheckIn")
                                    {
                                        <span class="badge bg-primary">Đã check-in</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Đã thanh toán</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">
                <em>Chưa có vé đã thanh toán / check-in cho sự kiện này.</em>
            </p>
        }
    </div>
</div>
