<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Hệ thống đặt vé sự kiện</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="d-flex flex-column min-vh-100 bg-light">

    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm border-bottom">
        <div class="container">

            @* Logo *@
            @if (User?.IsInRole("KhachHang") ?? false)
            {
                <a class="navbar-brand fw-bold text-primary" asp-controller="KhachHang" asp-action="Index">
                    Đặt Vé Sự Kiện
                </a>
            }
            else
            {
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">
                    Đặt Vé Sự Kiện
                </a>
            }

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNav">

                <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                    @* 🔵 Trang chủ *@
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    </li>

                    @* 🟢 Sự kiện theo vai trò *@
                    <li class="nav-item">
                        @if (User?.IsInRole("KhachHang") ?? false)
                        {
                            <a class="nav-link" asp-controller="KhachHang" asp-action="Index">Sự kiện</a>
                        }
                        else
                        {
                            <a class="nav-link" asp-controller="SuKien" asp-action="DanhSach">Sự kiện</a>
                        }
                    </li>

                    @* 🟡 ⭐ Vé của tôi (Chỉ khách hàng) *@
                    @if (User?.IsInRole("KhachHang") ?? false)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="KhachHang" asp-action="VeCuaToi">Vé của tôi</a>
                        </li>
                    }

                    @* 🟠 Quản lý sự kiện - Ban tổ chức *@
                    @if (User?.IsInRole("ToChuc") ?? false)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="BanToChuc" asp-action="Index">Quản lý sự kiện</a>
                        </li>
                    }

                    @* 🔴 Khu vực Admin *@
                    @if (User?.IsInRole("Admin") ?? false)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="Index">Duyệt sự kiện</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Admin" asp-action="YeuCauHoanHuy">
                                Yêu cầu hủy/hoàn vé
                            </a>
                        </li>
                    }

                </ul>

                <ul class="navbar-nav ms-auto">
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <li class="nav-item">
                            <span class="navbar-text me-3 fw-semibold text-dark">
                                Xin chào, @(User?.Identity?.Name ?? "Người dùng")
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="TaiKhoan" asp-action="DangXuat" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-primary btn-sm">
                                    Đăng xuất
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item me-2">
                            <a class="btn btn-outline-primary btn-sm" asp-controller="TaiKhoan" asp-action="DangNhap">
                                Đăng nhập
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm" asp-controller="TaiKhoan" asp-action="DangKy">
                                Đăng ký
                            </a>
                        </li>
                    }
                </ul>

            </div>

        </div>
    </nav>


    <main class="py-4 flex-fill">
        <div class="container">
            @RenderBody()
        </div>
    </main>

    <footer class="border-top py-3 bg-white mt-auto">
        <div class="container text-center text-muted small">
            &copy; @DateTime.Now.Year - Hệ thống đặt vé sự kiện trực tiếp & trực tuyến
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)

<script>
    // Hero slider: đổi background-image của .hero-banner.hero-slider
    document.addEventListener('DOMContentLoaded', function () {
        var hero = document.querySelector('.hero-banner.hero-slider');
        if (!hero) return;

        // 3 tấm hình bạn đã lưu trong wwwroot/images
        var images = [
            '/images/hero-event-1.jpg',
            '/images/hero-event-2.jpg',
            '/images/hero-event-3.jpg'
        ];

        var index = 0;

        function showSlide(i) {
            index = i;
            hero.classList.remove('hero-zoom');
            // restart animation
            void hero.offsetWidth;
            hero.style.backgroundImage = "url('" + images[index] + "')";
            hero.classList.add('hero-zoom');
        }

        // Hiển thị ảnh đầu tiên
        showSlide(0);

        // Đổi ảnh mỗi 7 giây
        setInterval(function () {
            var next = (index + 1) % images.length;
            showSlide(next);
        }, 7000);
    });
</script>

</body>
</html>
