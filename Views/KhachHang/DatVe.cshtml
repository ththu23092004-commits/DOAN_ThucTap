@model VeSuKienWeb.Models.KhachHang.DatVeKhVM

@{
    ViewData["Title"] = "Đặt vé";
}

<h2 class="mb-3">Đặt vé - @Model.TenSuKien</h2>

@if (TempData["ThongBao"] != null)
{
    <div class="alert alert-info">@TempData["ThongBao"]</div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light d-flex justify-content-between">
                <strong>Thông tin đặt vé</strong>
            </div>
            <div class="card-body">
                <form asp-action="DatVe" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="SuKienId" />
                    <input type="hidden" asp-for="LaSuKienTrucTiep" />
                    <input type="hidden" asp-for="LaWorkshop" />

                    @if (Model.LaSuKienTrucTiep)
                    {
                        <p class="mb-2">
                            <strong>Hình thức:</strong> Sự kiện trực tiếp - chọn chỗ ngồi trên sơ đồ.
                        </p>

                        <div class="mb-2">
                            <span class="badge bg-primary me-1">Ghế VIP</span>
                            <span class="badge bg-success">Ghế Thường</span>
                            <span class="badge bg-secondary ms-1">Đã đặt</span>
                        </div>

                        @if (Model.GheList != null && Model.GheList.Any())
                        {
                            var groupByHang = Model.GheList
                                .GroupBy(g => g.Hang)
                                .OrderBy(g => g.Key);

                            @if (!Model.LaWorkshop)
                            {
                                <div class="mb-3">
                                    <div class="stage-screen text-center">Màn hình / Sân khấu</div>
                                    <div class="stage-note text-center small text-muted mt-1">Khu vực giữa có tầm nhìn tốt hơn</div>
                                </div>
                            }
                            else
                            {
                                <div class="mb-3 text-center workshop-title-wrap">
                                    <div class="workshop-title">WORKSHOP</div>
                                    <div class="small text-muted mt-1">Sơ đồ ghế kiểu chữ U cho workshop</div>
                                </div>
                            }
                            @if (!Model.LaWorkshop)
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle text-center">
                                        <thead>
                                            <tr>
                                                <th class="text-start">Hàng / Ghế</th>
                                                @for (int c = 1; c <= Model.GheList.Max(g => g.Cot); c++)
                                                {
                                                    <th>@c</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in groupByHang)
                                            {
                                                <tr>
                                                    <td class="text-start fw-bold">@row.Key</td>
                                                    @for (int c = 1; c <= Model.GheList.Max(g => g.Cot); c++)
                                                    {
                                                        var ghe = row.FirstOrDefault(g => g.Cot == c);
                                                        if (ghe == null)
                                                        {
                                                            <td></td>
                                                        }
                                                        else
                                                        {
                                                            bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                            string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                            if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                            {
                                                                <td>
                                                                    <button type="button"
                                                                            class="btn btn-sm btn-secondary"
                                                                            disabled>
                                                                        @ghe.Cot
                                                                    </button>
                                                                </td>
                                                            }
                                                            else
                                                            {
                                                                <td>
                                                                    <label class="btn btn-sm @btnClass mb-0">
                                                                        <input type="checkbox"
                                                                               name="GheChonIds"
                                                                               value="@ghe.ChoNgoiId"
                                                                               class="form-check-input me-1" />
                                                                        @ghe.Cot
                                                                    </label>
                                                                </td>
                                                            }
                                                        }
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                var workshopRows = groupByHang.ToList();
                                var leftRow = workshopRows.FirstOrDefault();
                                var rightRow = workshopRows.Count > 1 ? workshopRows[1] : null;
                                var bottomRows = workshopRows.Skip(2).ToList();
                                var bottomSeats = bottomRows.SelectMany(r => r.OrderBy(g => g.Cot)).ToList();

                                <div class="workshop-layout-u">
                                    <div class="workshop-u-body">
                                        <div class="workshop-u-col">
                                            @if (leftRow != null)
                                            {
                                                @foreach (var ghe in leftRow.OrderBy(g => g.Cot))
                                                {
                                                    bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                    string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                    if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary workshop-seat" disabled>
                                                            @leftRow.Key@ghe.Cot
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <label class="btn btn-sm @btnClass mb-0 workshop-seat">
                                                            <input type="checkbox"
                                                                   name="GheChonIds"
                                                                   value="@ghe.ChoNgoiId"
                                                                   class="form-check-input me-1" />
                                                            @leftRow.Key@ghe.Cot
                                                        </label>
                                                    }
                                                }
                                            }
                                        </div>

                                        <div class="workshop-u-center"></div>

                                        <div class="workshop-u-col">
                                            @if (rightRow != null)
                                            {
                                                @foreach (var ghe in rightRow.OrderBy(g => g.Cot))
                                                {
                                                    bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                    string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                    if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary workshop-seat" disabled>
                                                            @rightRow.Key@ghe.Cot
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <label class="btn btn-sm @btnClass mb-0 workshop-seat">
                                                            <input type="checkbox"
                                                                   name="GheChonIds"
                                                                   value="@ghe.ChoNgoiId"
                                                                   class="form-check-input me-1" />
                                                            @rightRow.Key@ghe.Cot
                                                        </label>
                                                    }
                                                }
                                            }
                                        </div>
                                    </div>

                                    <div class="workshop-u-bottom">
                                        @foreach (var ghe in bottomSeats)
                                        {
                                            bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                            string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                            if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                            {
                                                <button type="button" class="btn btn-sm btn-secondary workshop-seat" disabled>
                                                    @ghe.Hang@ghe.Cot
                                                </button>
                                            }
                                            else
                                            {
                                                <label class="btn btn-sm @btnClass mb-0 workshop-seat">
                                                    <input type="checkbox"
                                                           name="GheChonIds"
                                                           value="@ghe.ChoNgoiId"
                                                           class="form-check-input me-1" />
                                                    @ghe.Hang@ghe.Cot
                                                </label>
                                            }
                                        }
                                    </div>
                                </div>
                            }

                            <div class="small text-muted">
                                Chọn 1 hoặc nhiều ghế trống để đặt vé (tối đa 10 ghế cho mỗi lần đặt).
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0"><em>Chưa có sơ đồ ghế.</em></p>
                        }
                    }
                    else
                    {
                        <p class="mb-3">
                            <strong>Hình thức:</strong> Sự kiện trực tuyến - hệ thống tự áp dụng loại vé mặc định, bạn chỉ cần chọn số lượng.
                        </p>

                        @* Ẩn LoaiVeId – đã được gán sẵn ở GET DatVe trong controller *@
                        <input type="hidden" asp-for="LoaiVeId" />

                        <div class="mb-3">
                            <label class="form-label">Số lượng vé</label>
                            <input asp-for="SoLuong" type="number" min="1" max="10" class="form-control" />
                            <div class="form-text">
                                Mỗi lần đặt tối đa 10 vé.
                            </div>
                        </div>
                    }

                    <button type="submit" class="btn btn-primary">
                        Tiếp tục thanh toán
                    </button>
                    <a asp-action="ChiTiet"
                       asp-route-id="@Model.SuKienId"
                       class="btn btn-outline-secondary ms-2">
                        &laquo; Quay lại chi tiết
                    </a>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <strong>Lưu ý</strong>
            </div>
            <div class="card-body small text-muted">
                <ul class="mb-0">
                    <li>Sau bước này, hệ thống sẽ tạo đơn hàng và chuyển sang màn hình thanh toán.</li>
                    <li></li>
                    <li>Với sự kiện trực tuyến, link tham gia và mật khẩu sẽ hiển thị sau khi thanh toán thành công.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Giới hạn tối đa 10 ghế được chọn cho sự kiện trực tiếp
        document.addEventListener('DOMContentLoaded', function () {
            var maxSeats = 10;
            var checkboxes = document.querySelectorAll('input[name="GheChonIds"]');

            if (checkboxes && checkboxes.length > 0) {
                checkboxes.forEach(function (cb) {
                    cb.addEventListener('change', function () {
                        var checked = document.querySelectorAll('input[name="GheChonIds"]:checked');
                        if (checked.length > maxSeats) {
                            // bỏ tick cuối cùng
                            this.checked = false;
                            alert('Bạn chỉ được chọn tối đa ' + maxSeats + ' ghế trong một lần đặt.');
                        }
                    });
                });
            }
        });
    </script>
}

<style>
    .stage-screen {
        background: repeating-linear-gradient(
            -45deg,
            #f8f9fa,
            #f8f9fa 8px,
            #eef1f4 8px,
            #eef1f4 16px
        );
        border: 1px solid #d6dde5;
        border-radius: 999px;
        color: #b54708;
        font-weight: 700;
        letter-spacing: .4px;
        padding: 10px 16px;
        box-shadow: inset 0 1px 0 #fff, 0 2px 6px rgba(0, 0, 0, .06);
    }

    .stage-note {
        font-style: italic;
    }

    .workshop-title {
        font-size: 2rem;
        font-weight: 800;
        letter-spacing: 1px;
    }

    .workshop-layout-u {
        display: flex;
        flex-direction: column;
        gap: 12px;
        max-width: 760px;
    }

    .workshop-u-body {
        display: flex;
        justify-content: space-between;
        align-items: stretch;
        gap: 18px;
    }

    .workshop-u-col {
        display: flex;
        flex-direction: column;
        flex-wrap: wrap;
        gap: 10px;
        min-width: 120px;
    }

    .workshop-u-center {
        flex: 1;
        border-left: 4px solid #2f2f2f;
        border-right: 4px solid #2f2f2f;
        border-bottom: 4px solid #2f2f2f;
        border-radius: 0 0 6px 6px;
        min-height: 180px;
        background: rgba(240, 248, 245, 0.45);
    }

    .workshop-u-bottom {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 8px;
        padding-top: 10px;
        max-width: 620px;
        margin: 0 auto;
    }

    .workshop-seat {
        min-width: 76px;
    }

    @@media (max-width: 768px) {
        .workshop-u-body {
            gap: 10px;
        }

        .workshop-u-center {
            min-height: 120px;
        }

        .workshop-seat {
            min-width: 64px;
            font-size: 0.8rem;
        }
    }
</style>
