@model VeSuKienWeb.Models.KhachHang.DatVeKhVM

@{
    ViewData["Title"] = "Đặt vé";
}

<h2 class="mb-3">Đặt vé - @Model.TenSuKien</h2>

@if (TempData["ThongBao"] != null)
{
    <div class="alert alert-info">@TempData["ThongBao"]</div>
}

<div class="row">
    <div class="col-md-8">
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-light d-flex justify-content-between">
                <strong>Thông tin đặt vé</strong>
            </div>
            <div class="card-body">
                <form asp-action="DatVe" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="SuKienId" />
                    <input type="hidden" asp-for="LaSuKienTrucTiep" />
                    <input type="hidden" asp-for="LaWorkshop" />

                    @if (Model.LaSuKienTrucTiep)
                    {
                        <p class="mb-2">
                            <strong>Hình thức:</strong> Sự kiện trực tiếp - chọn chỗ ngồi trên sơ đồ.
                        </p>

                        <div class="mb-2 seat-legend">
                            <span class="badge bg-primary me-1">Ghế VIP</span>
                            <span class="badge bg-success">Ghế Thường</span>
                            <span class="badge bg-secondary ms-1">Đã đặt</span>
                        </div>

                        @if (Model.GheList != null && Model.GheList.Any())
                        {
                            var groupByHang = Model.GheList
                                .GroupBy(g => g.Hang)
                                .OrderBy(g => g.Key);

                            @if (!Model.LaWorkshop)
                            {
                                <div class="mb-3">
                                    <div class="stage-screen text-center">Màn hình / Sân khấu</div>
                                    <div class="stage-note text-center small text-muted mt-1">Khu vực giữa có tầm nhìn tốt hơn</div>
                                </div>
                            }
                            else
                            {
                                <div class="mb-3 text-center workshop-title-wrap">
                                    <div class="workshop-title">WORKSHOP</div>
                                    <div class="small text-muted mt-1">Sơ đồ ghế kiểu chữ U cho workshop</div>
                                </div>
                            }
                            @if (!Model.LaWorkshop)
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm align-middle text-center">
                                        <thead>
                                            <tr>
                                                <th class="text-start">Hàng / Ghế</th>
                                                @for (int c = 1; c <= Model.GheList.Max(g => g.Cot); c++)
                                                {
                                                    <th>@c</th>
                                                }
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in groupByHang)
                                            {
                                                <tr>
                                                    <td class="text-start fw-bold">@row.Key</td>
                                                    @for (int c = 1; c <= Model.GheList.Max(g => g.Cot); c++)
                                                    {
                                                        var ghe = row.FirstOrDefault(g => g.Cot == c);
                                                        if (ghe == null)
                                                        {
                                                            <td></td>
                                                        }
                                                        else
                                                        {
                                                            bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                            string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                            if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                            {
                                                                <td>
                                                                    <button type="button"
                                                                            class="btn btn-sm btn-secondary"
                                                                            disabled>
                                                                        @ghe.Cot
                                                                    </button>
                                                                </td>
                                                            }
                                                            else
                                                            {
                                                                <td>
                                                                    <label class="btn btn-sm @btnClass mb-0">
                                                                        <input type="checkbox"
                                                                               name="GheChonIds"
                                                                               value="@ghe.ChoNgoiId"
                                                                               class="form-check-input me-1" />
                                                                        @ghe.Cot
                                                                    </label>
                                                                </td>
                                                            }
                                                        }
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                var workshopRows = Model.GheList
                                    .GroupBy(g => g.Hang)
                                    .OrderBy(g => g.Key)
                                    .Select(g => g.OrderBy(x => x.Cot).ToList())
                                    .ToList();

                                var leftRowSeats = workshopRows.Count > 0 ? workshopRows[0] : new List<VeSuKienWeb.Models.KhachHang.DatVeGheItemVM>();
                                var rightRowSeats = workshopRows.Count > 1 ? workshopRows[1] : new List<VeSuKienWeb.Models.KhachHang.DatVeGheItemVM>();
                                var bottomSeats = workshopRows.Skip(2).SelectMany(r => r).ToList();

                                // Ưu tiên giữ cạnh trái/phải theo đúng hàng chữ cái đầu (A/B) để không lẫn ghế từ hàng khác lên cánh dọc.
                                var leftSeats = leftRowSeats.ToList();
                                var rightSeats = rightRowSeats.ToList();

                                var bottomInnerCount = (int)Math.Ceiling(bottomSeats.Count * 0.4);
                                var innerBottomRow = bottomSeats.Take(bottomInnerCount).ToList();
                                var outerBottomSeats = bottomSeats.Skip(bottomInnerCount).ToList();

                                var leftOuterSeats = leftSeats.Where((g, idx) => idx % 2 == 0).ToList();
                                var leftInnerSeats = leftSeats.Where((g, idx) => idx % 2 == 1).ToList();
                                var rightInnerSeats = rightSeats.Where((g, idx) => idx % 2 == 0).ToList();
                                var rightOuterSeats = rightSeats.Where((g, idx) => idx % 2 == 1).ToList();

                                 <div class="workshop-layout-u">
                                     <div class="workshop-ambient workshop-ambient-left"></div>
                                     <div class="workshop-ambient workshop-ambient-right"></div>
                                    <div class="workshop-container">
                                        <div class="u-top-part">
                                            <div class="side-wing left">
                                                <div class="lane outer">
                                                @foreach (var ghe in leftOuterSeats)
                                                {
                                                    bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                    string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                    if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary workshop-seat" disabled>
                                                            @ghe.Hang@ghe.Cot
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <label class="btn btn-sm @btnClass mb-0 workshop-seat">
                                                            <input type="checkbox"
                                                                   name="GheChonIds"
                                                                   value="@ghe.ChoNgoiId"
                                                                   class="form-check-input me-1" />
                                                            @ghe.Hang@ghe.Cot
                                                        </label>
                                                    }
                                                }
                                                </div>

                                                <div class="table-vertical"></div>

                                                <div class="lane inner">
                                                @foreach (var ghe in leftInnerSeats)
                                                {
                                                    bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                    string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                    if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary workshop-seat" disabled>
                                                            @ghe.Hang@ghe.Cot
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <label class="btn btn-sm @btnClass mb-0 workshop-seat">
                                                            <input type="checkbox"
                                                                   name="GheChonIds"
                                                                   value="@ghe.ChoNgoiId"
                                                                   class="form-check-input me-1" />
                                                            @ghe.Hang@ghe.Cot
                                                        </label>
                                                    }
                                                }
                                                </div>
                                            </div>

                                            <div class="u-center-void"></div>

                                            <div class="side-wing right">
                                                <div class="lane inner">
                                                @foreach (var ghe in rightInnerSeats)
                                                {
                                                    bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                    string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                    if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary workshop-seat" disabled>
                                                            @ghe.Hang@ghe.Cot
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <label class="btn btn-sm @btnClass mb-0 workshop-seat">
                                                            <input type="checkbox"
                                                                   name="GheChonIds"
                                                                   value="@ghe.ChoNgoiId"
                                                                   class="form-check-input me-1" />
                                                            @ghe.Hang@ghe.Cot
                                                        </label>
                                                    }
                                                }
                                                </div>

                                                <div class="table-vertical"></div>

                                                <div class="lane outer">
                                                @foreach (var ghe in rightOuterSeats)
                                                {
                                                    bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                    string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                    if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <button type="button" class="btn btn-sm btn-secondary workshop-seat" disabled>
                                                            @ghe.Hang@ghe.Cot
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <label class="btn btn-sm @btnClass mb-0 workshop-seat">
                                                            <input type="checkbox"
                                                                   name="GheChonIds"
                                                                   value="@ghe.ChoNgoiId"
                                                                   class="form-check-input me-1" />
                                                            @ghe.Hang@ghe.Cot
                                                        </label>
                                                    }
                                                }
                                                </div>
                                            </div>

                                        </div>

                                        <div class="u-bottom-part">
                                            @if (innerBottomRow.Any())
                                            {
                                                <div class="lane inner-horizontal">
                                                    @foreach (var ghe in innerBottomRow)
                                                    {
                                                        bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                        string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                        if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                        {
                                                            <button type="button" class="btn btn-sm btn-secondary workshop-seat" disabled>
                                                                @ghe.Hang@ghe.Cot
                                                            </button>
                                                        }
                                                        else
                                                        {
                                                            <label class="btn btn-sm @btnClass mb-0 workshop-seat">
                                                                <input type="checkbox"
                                                                       name="GheChonIds"
                                                                       value="@ghe.ChoNgoiId"
                                                                       class="form-check-input me-1" />
                                                                @ghe.Hang@ghe.Cot
                                                            </label>
                                                        }
                                                    }
                                                </div>
                                            }

                                            <div class="table-horizontal"></div>

                                            <div class="lane outer-horizontal">
                                            @foreach (var ghe in outerBottomSeats)
                                            {
                                                bool laVip = ghe.TenLoaiVe?.ToLower().Contains("vip") == true;
                                                string btnClass = laVip ? "btn-outline-primary" : "btn-outline-success";

                                                if (!string.Equals(ghe.TrangThai, "Trong", StringComparison.OrdinalIgnoreCase))
                                                {
                                                    <button type="button" class="btn btn-sm btn-secondary workshop-seat" disabled>
                                                        @ghe.Hang@ghe.Cot
                                                    </button>
                                                }
                                                else
                                                {
                                                    <label class="btn btn-sm @btnClass mb-0 workshop-seat">
                                                        <input type="checkbox"
                                                               name="GheChonIds"
                                                               value="@ghe.ChoNgoiId"
                                                               class="form-check-input me-1" />
                                                        @ghe.Hang@ghe.Cot
                                                    </label>
                                                }
                                            }
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <div class="small text-muted">
                                Chọn 1 hoặc nhiều ghế trống để đặt vé (tối đa 10 ghế cho mỗi lần đặt).
                            </div>
                        }
                        else
                        {
                            <p class="text-muted mb-0"><em>Chưa có sơ đồ ghế.</em></p>
                        }
                    }
                    else
                    {
                        <p class="mb-3">
                            <strong>Hình thức:</strong> Sự kiện trực tuyến - hệ thống tự áp dụng loại vé mặc định, bạn chỉ cần chọn số lượng.
                        </p>

                        @* Ẩn LoaiVeId – đã được gán sẵn ở GET DatVe trong controller *@
                        <input type="hidden" asp-for="LoaiVeId" />

                        <div class="mb-3">
                            <label class="form-label">Số lượng vé</label>
                            <input asp-for="SoLuong" type="number" min="1" max="10" class="form-control" />
                            <div class="form-text">
                                Mỗi lần đặt tối đa 10 vé.
                            </div>
                        </div>
                    }

                    <button type="submit" class="btn btn-primary">
                        Tiếp tục thanh toán
                    </button>
                    <a asp-action="ChiTiet"
                       asp-route-id="@Model.SuKienId"
                       class="btn btn-outline-secondary ms-2">
                        &laquo; Quay lại chi tiết
                    </a>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-header bg-light">
                <strong>Lưu ý</strong>
            </div>
            <div class="card-body small text-muted">
                <ul class="mb-0">
                    <li>Sau bước này, hệ thống sẽ tạo đơn hàng và chuyển sang màn hình thanh toán.</li>
                    <li>Ghế VIP và ghế thường hiển thị theo màu khác nhau để dễ chọn nhanh.</li>
                    <li>Với sự kiện trực tuyến, link tham gia và mật khẩu sẽ hiển thị sau khi thanh toán thành công.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Giới hạn tối đa 10 ghế được chọn cho sự kiện trực tiếp
        document.addEventListener('DOMContentLoaded', function () {
            var maxSeats = 10;
            var checkboxes = document.querySelectorAll('input[name="GheChonIds"]');

            if (checkboxes && checkboxes.length > 0) {
                checkboxes.forEach(function (cb) {
                    cb.addEventListener('change', function () {
                        var checked = document.querySelectorAll('input[name="GheChonIds"]:checked');
                        if (checked.length > maxSeats) {
                            // bỏ tick cuối cùng
                            this.checked = false;
                            alert('Bạn chỉ được chọn tối đa ' + maxSeats + ' ghế trong một lần đặt.');
                        }
                    });
                });
            }
        });
    </script>
}

<style>
    .stage-screen {
        background: repeating-linear-gradient(
            -45deg,
            #f8f9fa,
            #f8f9fa 8px,
            #eef1f4 8px,
            #eef1f4 16px
        );
        border: 1px solid #d6dde5;
        border-radius: 999px;
        color: #b54708;
        font-weight: 700;
        letter-spacing: .4px;
        padding: 10px 16px;
        box-shadow: inset 0 1px 0 #fff, 0 2px 6px rgba(0, 0, 0, .06);
    }

    .stage-note {
        font-style: italic;
    }

    .workshop-title {
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: 1.4px;
        color: #0f172a;
    }

    .workshop-layout-u {
        position: relative;
        overflow: hidden;
        border-radius: 18px;
        background: radial-gradient(circle at top right, #eefaf6 0%, #d8f2ea 40%, #c9e8df 100%);
        padding: 20px 18px;
        border: 1px solid #b9ddd2;
        box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
    }

    .workshop-ambient {
        position: absolute;
        width: 180px;
        height: 180px;
        border-radius: 999px;
        pointer-events: none;
        filter: blur(2px);
        opacity: .45;
    }

    .workshop-ambient-left {
        top: -50px;
        left: -40px;
        background: radial-gradient(circle, #c8efe1 0%, transparent 70%);
    }

    .workshop-ambient-right {
        bottom: -60px;
        right: -30px;
        background: radial-gradient(circle, #bfe7d8 0%, transparent 70%);
    }

    .seat-legend .badge {
        border-radius: 999px;
        padding: 7px 11px;
        font-weight: 700;
        letter-spacing: .2px;
    }

    .workshop-container {
        display: flex;
        flex-direction: column;
        gap: 10px;
        max-width: 760px;
        margin: 0 auto;
    }

    .u-top-part {
        display: flex;
        justify-content: center;
        align-items: stretch;
        gap: 8px;
    }

    .side-wing {
        display: flex;
        align-items: stretch;
        gap: 8px;
    }

    .u-center-void {
        flex: 1;
        min-width: 170px;
    }

    .lane {
        display: flex;
        gap: 8px;
    }

    .side-wing .lane {
        flex-direction: column;
        width: 92px;
    }

    .table-vertical {
        width: 30px;
        min-height: 230px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.35), rgba(225, 245, 238, 0.62));
        border: 6px solid #0f172a;
        border-bottom: 0;
        border-radius: 8px 8px 0 0;
        align-self: stretch;
    }

    .u-bottom-part {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .inner-horizontal,
    .outer-horizontal {
        flex-direction: row;
        justify-content: center;
        flex-wrap: wrap;
    }

    .table-horizontal {
        width: min(620px, 100%);
        min-height: 34px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.35), rgba(225, 245, 238, 0.62));
        border-left: 6px solid #0f172a;
        border-right: 6px solid #0f172a;
        border-bottom: 6px solid #0f172a;
        border-radius: 0 0 12px 12px;
    }

    .workshop-seat {
        min-width: 70px;
        border-radius: 999px;
        font-weight: 600;
        box-shadow: 0 2px 6px rgba(15, 23, 42, 0.08);
        transition: transform .15s ease, box-shadow .15s ease;
    }

    .workshop-seat:hover {
        transform: translateY(-1px);
        box-shadow: 0 5px 12px rgba(15, 23, 42, 0.15);
    }

    @@media (max-width: 768px) {
        .workshop-layout-u {
            padding: 14px 10px;
        }

        .u-top-part {
            gap: 6px;
        }

        .u-center-void {
            min-width: 60px;
        }

        .side-wing {
            gap: 6px;
        }

        .side-wing .lane {
            width: 58px;
            gap: 6px;
        }

        .table-vertical {
            width: 20px;
            min-height: 150px;
            border-width: 4px;
            border-bottom: 0;
        }

        .u-bottom-part {
            gap: 6px;
        }

        .table-horizontal {
            min-height: 24px;
            border-left-width: 4px;
            border-right-width: 4px;
            border-bottom-width: 4px;
        }

        .workshop-seat {
            min-width: 58px;
            font-size: 0.8rem;
        }
    }
</style>
