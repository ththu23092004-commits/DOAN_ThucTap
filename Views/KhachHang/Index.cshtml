@model List<VeSuKienWeb.Models.KhachHang.SuKienListItemKhVM>

@{
    ViewData["Title"] = "Sự kiện";
    string? search = ViewBag.Search as string;
}



<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2 class="mb-0">Tất cả sự kiện</h2>
        <div class="text-muted small">
            Danh sách các sự kiện đã được duyệt và mở cho khách đặt vé.
        </div>
    </div>
<form method="get" class="search-box d-flex align-items-center">
    <div class="input-group">
        <span class="input-group-text bg-white border-end-0">
            <i class="bi bi-search text-muted"></i>
        </span>
        <input type="text"
               name="search"
               value="@search"
               class="form-control border-start-0"
               placeholder="Tìm kiếm sự kiện, ca sĩ, địa điểm..." />
        <button type="submit" class="btn btn-primary px-4">
            Tìm kiếm
        </button>
    </div>
</form>
</div>

@if (Model != null && Model.Any())
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var sk in Model)
        {
            var thoiGianStr = $"{sk.ThoiGianBatDau:HH:mm dd/MM/yyyy} - {sk.ThoiGianKetThuc:HH:mm dd/MM/yyyy}";
            <div class="col">
                <div class="card h-100 shadow-sm border-0">

                    @* ⭐ HÌNH ẢNH SỰ KIỆN *@
                    <img class="card-img-top"
                         src="@Url.Content(string.IsNullOrWhiteSpace(sk.AnhSuKien) ? "~/images/default-event.jpg" : sk.AnhSuKien)"
                         alt="@sk.TenSuKien"
                         style="height: 180px; object-fit: cover;" />

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <h5 class="card-title mb-0">@sk.TenSuKien</h5>
                                @if (!string.IsNullOrWhiteSpace(sk.TenLoai))
                                {
                                    <span class="badge bg-light text-dark border mt-1">
                                        @sk.TenLoai
                                    </span>
                                }
                            </div>
                            <div class="text-end">
                                @if (sk.DaKetThuc)
                                {
                                    <span class="badge bg-secondary">Đã diễn ra</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Còn mở</span>
                                }
                            </div>
                        </div>

                        <p class="text-muted small mb-1">
                            <i class="bi bi-clock"></i> @thoiGianStr
                        </p>

                        @if (!string.IsNullOrWhiteSpace(sk.DiaDiem))
                        {
                            <p class="text-muted small mb-1">
                                <i class="bi bi-geo-alt"></i> @sk.DiaDiem
                            </p>
                        }

                        @if (sk.GiaTu.HasValue)
                        {
                            <p class="fw-semibold mb-2">
                                Giá từ: @sk.GiaTu.Value.ToString("N0") đ
                            </p>
                        }

                        <div class="mt-auto d-flex justify-content-between align-items-center">
                            <span class="text-muted small">
                                @if (sk.DaKetThuc)
                                {
                                    <text>Sự kiện đã kết thúc</text>
                                }
                                else
                                {
                                    <text>Sự kiện đang mở</text>
                                }
                            </span>

                            <a asp-action="ChiTiet"
                               asp-route-id="@sk.SuKienId"
                               class="btn btn-outline-primary btn-sm">
                                Xem chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-light border">
        <div class="fw-semibold">Chưa có sự kiện nào được duyệt.</div>
        <div class="small text-muted">Vui lòng quay lại sau.</div>
    </div>
}
