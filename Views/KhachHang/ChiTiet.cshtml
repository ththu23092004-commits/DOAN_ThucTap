@model VeSuKienWeb.Models.KhachHang.SuKienChiTietKhVM

@{
    var sk = Model.SuKien;
    var loai = Model.LoaiSuKien;
    var toChuc = Model.ToChuc;
    var diaDiem = Model.DiaDiem;
    var online = Model.SuKienTrucTuyen;

    ViewData["Title"] = "Chi tiết sự kiện";

    // ✅ kiểm tra đăng nhập & vai trò (sửa CS8602)
    bool daDangNhap = User?.Identity?.IsAuthenticated ?? false;
    bool laKhachHang = User?.IsInRole("KhachHang") ?? false;

    // ✅ tính sẵn returnUrl để dùng khi yêu cầu đăng nhập
    var returnUrl = Context.Request.Path + Context.Request.QueryString;
}

<div class="row mb-3">
    <div class="col-md-8">
        <h2 class="fw-bold">@sk.TenSuKien</h2>
        <div class="d-flex flex-wrap align-items-center gap-2 text-muted small mt-1">
            @if (loai != null)
            {
                <span class="badge bg-secondary">@loai.TenLoai</span>
            }
            <span>
                @sk.ThoiGianBatDau.ToString("HH:mm dd/MM/yyyy")
                &rarr;
                @sk.ThoiGianKetThuc.ToString("HH:mm dd/MM/yyyy")
            </span>
            @if (toChuc != null)
            {
                <span>&bull; Tổ chức: <strong>@toChuc.TenToChuc</strong></span>
            }
        </div>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
        @if (Model.DiemTrungBinh.HasValue)
        {
            <div class="text-muted small">Đánh giá trung bình</div>
            <div class="fs-4 fw-bold text-warning">
                @Model.DiemTrungBinh.Value.ToString("0.0") <span class="fs-6 text-dark">/ 5</span>
            </div>
            <div class="small text-muted">
                @Model.TongSoDanhGia đánh giá
            </div>
        }
        else
        {
            <div class="small text-muted">Chưa có đánh giá cho sự kiện này.</div>
        }
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-light">
                <strong>Giới thiệu sự kiện</strong>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(sk.MoTaChiTiet))
                {
                    <p>@sk.MoTaChiTiet</p>
                }
                else
                {
                    <p class="text-muted"><em>Chưa có mô tả chi tiết.</em></p>
                }
            </div>
        </div>

        @if (diaDiem != null)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-light">
                    <strong>Sự kiện trực tiếp</strong>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Địa điểm:</strong> @diaDiem.TenDiaDiem</p>
                    <p class="mb-1"><strong>Địa chỉ:</strong> @diaDiem.DiaChi</p>
                    <p class="mb-1"><strong>Tổng số ghế:</strong> @diaDiem.SoChoNgoi</p>
                    @if (!string.IsNullOrWhiteSpace(diaDiem.BanDo))
                    {
                        <p class="mb-0">
                            <strong>Bản đồ:</strong>
                            <a href="@diaDiem.BanDo" target="_blank">Mở Google Maps</a>
                        </p>
                    }
                </div>
            </div>
        }

        @if (online != null)
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-light">
                    <strong>Sự kiện trực tuyến</strong>
                </div>
                <div class="card-body">
                    <p class="mb-1"><strong>Nền tảng:</strong> @online.NenTang</p>
                    <p class="mb-1 text-muted small">
                        Link tham gia và mật khẩu phòng sẽ được hiển thị sau khi bạn đặt vé và thanh toán thành công.
                    </p>
                    @if (!string.IsNullOrWhiteSpace(online.HuongDan))
                    {
                        <p class="mb-0">
                            <strong>Hướng dẫn:</strong><br />
                            @online.HuongDan
                        </p>
                    }
                </div>
            </div>
        }

        <!-- ====== ĐÁNH GIÁ TỪ NGƯỜI THAM GIA (HIỆN CHỈ HIỂN THỊ THÔNG BÁO) ====== -->
        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-light">
                <strong>Đánh giá từ người tham gia</strong>
            </div>
            <div class="card-body">
                @if (Model.TongSoDanhGia > 0 && Model.DiemTrungBinh.HasValue)
                {
                    <p class="mb-1">
                        Đánh giá trung bình: <strong>@Model.DiemTrungBinh.Value.ToString("0.0") / 5</strong>
                        (@Model.TongSoDanhGia lượt đánh giá)
                    </p>
                    <p class="text-muted mb-0">
                        Tính năng hiển thị chi tiết từng đánh giá sẽ được bổ sung sau.
                    </p>
                }
                else
                {
                    <p class="text-muted mb-0">
                        <em>Chưa có đánh giá nào cho sự kiện này.</em>
                    </p>
                }
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-light">
                <strong>Thông tin vé</strong>
            </div>
            <div class="card-body">
                @if (Model.LoaiVes != null && Model.LoaiVes.Any())
                {
                    <table class="table table-sm align-middle mb-3">
                        <thead>
                            <tr>
                                <th>Loại vé</th>
                                <th>Giá</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var lv in Model.LoaiVes)
                            {
                                <tr>
                                    <td>@lv.TenLoai</td>
                                    <td>@lv.GiaVe.ToString("N0") đ</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted mb-0"><em>Chưa cấu hình loại vé.</em></p>
                }
            </div>
        </div>

        <div class="card mb-3 shadow-sm">
            <div class="card-body text-center">
                @if (TempData["ThongBao"] != null)
                {
                    <div class="alert alert-info py-2 mb-2">
                        @TempData["ThongBao"]
                    </div>
                }

                @if (Model.CoTheDatVe)
                {
                    @* Sự kiện còn mở đặt vé *@
                    @if (!daDangNhap)
                    {
                        <a asp-controller="TaiKhoan"
                           asp-action="DangNhap"
                           asp-route-returnUrl="@returnUrl"
                           class="btn btn-primary w-100 mb-2">
                            Đăng nhập để đặt vé
                        </a>
                        <div class="small text-muted">
                            Bạn cần đăng nhập với vai trò Khách hàng để đặt vé.
                        </div>
                    }
                    else if (laKhachHang)
                    {
                        <a asp-action="DatVe"
                           asp-route-id="@sk.SuKienId"
                           class="btn btn-primary w-100 mb-2">
                            Đặt vé ngay
                        </a>
                        <div class="small text-muted">
                            Vui lòng hoàn tất thanh toán trong thời gian quy định.
                        </div>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark mb-2">
                            Bạn không phải tài khoản Khách hàng
                        </span>
                        <div class="small text-muted">
                            Vui lòng đăng xuất và đăng nhập bằng tài khoản Khách hàng để đặt vé.
                        </div>
                    }
                }
                else
                {
                    <span class="badge bg-secondary mb-2">
                        Sự kiện đã kết thúc · Không thể đặt vé
                    </span>
                    <div class="small text-muted">
                        Bạn vẫn có thể xem thông tin và đánh giá từ người tham gia.
                    </div>
                }
            </div>
        </div>
    </div>
</div>
