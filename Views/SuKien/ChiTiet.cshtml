@model VeSuKienWeb.Models.SuKienViewModels.SuKienChiTietKhachVM

@{
    var sk = Model.SuKien;
    var loai = Model.LoaiSuKien;
    var toChuc = Model.ToChuc;
    var diaDiem = Model.DiaDiem;
    var online = Model.SuKienTrucTuyen;

    ViewData["Title"] = sk.TenSuKien;

    var loaiTen = loai?.TenLoai ?? "";
    var loaiLower = loaiTen.ToLower();

    // ⭐ phân quyền
    var laQuanTri = User.IsInRole("Admin") || User.IsInRole("ToChuc");
    var daMuaVe = Model.DaMuaVe;

    // ⭐ kiểm tra sự kiện đã diễn ra
    bool daDienRa = sk.ThoiGianKetThuc < DateTime.Now;
}

<div class="row mb-4">
    <div class="col-md-8">
        <h2 class="fw-bold">@sk.TenSuKien</h2>
        <div class="d-flex flex-wrap align-items-center gap-2 text-muted small mt-1">

            @if (loai != null)
            {
                <span class="badge bg-secondary">@loai.TenLoai</span>
            }

            <span>
                @sk.ThoiGianBatDau.ToString("HH:mm dd/MM/yyyy")
                →
                @sk.ThoiGianKetThuc.ToString("HH:mm dd/MM/yyyy")
            </span>

            @if (toChuc != null)
            {
                <span>• Tổ chức: <strong>@toChuc.TenToChuc</strong></span>
            }
        </div>
    </div>

    <div class="col-md-4 text-md-end mt-3 mt-md-0">

        @if (sk.GiaVeMacDinh.HasValue)
        {
            <div class="text-muted small">Giá từ</div>
            <div class="fs-4 fw-bold text-primary">@sk.GiaVeMacDinh.Value.ToString("N0") đ</div>
        }
        else
        {
            <div class="text-muted small">Giá vé</div>
            <div class="fs-6"><em>Chưa cập nhật</em></div>
        }

        <!-- ⭐ TRẠNG THÁI SỰ KIỆN ĐÃ DIỄN RA / CHƯA DIỄN RA -->
        @if (daDienRa)
        {
            <div class="alert alert-secondary mt-3 mb-0">
                <i class="bi bi-clock-history"></i> Sự kiện này đã diễn ra.
            </div>
        }
        else if (!laQuanTri)
        {
            @* ⭐ KHÁCH (KHÔNG PHẢI ADMIN/BTC) MỚI ĐƯỢC ĐẶT VÉ *@

            @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("KhachHang"))
            {
                <!-- ĐÃ ĐĂNG NHẬP VỚI VAI TRÒ KHÁCH HÀNG → ĐẶT VÉ -->
                <a asp-controller="KhachHang"
                   asp-action="DatVe"
                   asp-route-id="@sk.SuKienId"
                   class="btn btn-primary btn-lg mt-2">
                    Đặt vé
                </a>
            }
else
{
    <a asp-controller="TaiKhoan"
       asp-action="DangNhap"
       asp-route-returnUrl="@Url.Action("ChiTiet", "SuKien", new { id = sk.SuKienId })"
       class="btn btn-primary btn-lg mt-2">
        Đăng nhập để đặt vé
    </a>
    <div class="small text-muted mt-1">
        Bạn cần đăng nhập với vai trò <strong>Khách hàng</strong> để đặt vé.
    </div>
}

        }
        else
        {
            <!-- ⭐ ADMIN + BTC -> KHÔNG HIỂN THỊ NÚT ĐẶT VÉ -->
            <div class="text-muted small mt-2">
                Bạn đang xem với vai trò quản trị / ban tổ chức.
            </div>
        }

    </div>
</div>


<div class="row">
    <!-- CỘT TRÁI -->
    <div class="col-md-8">

        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-light"><strong>Giới thiệu sự kiện</strong></div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(sk.MoTaChiTiet))
                {
                    <p>@sk.MoTaChiTiet</p>
                }
                else
                {
                    <p class="text-muted"><em>Chưa có mô tả chi tiết.</em></p>
                }
            </div>
        </div>

        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-light"><strong>Loại vé & giá vé</strong></div>
            <div class="card-body">
                @if (Model.LoaiVes != null && Model.LoaiVes.Any())
                {
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Loại vé</th>
                                <th>Giá</th>
                                <th>Số lượng</th>
                                <th>Mô tả</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var v in Model.LoaiVes)
                            {
                                <tr>
                                    <td>@v.TenLoai</td>
                                    <td>@v.GiaVe.ToString("N0") đ</td>
                                    <td>@v.SoLuong</td>
                                    <td>@(string.IsNullOrWhiteSpace(v.MoTa) ? "-" : v.MoTa)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted"><em>Chưa cấu hình loại vé.</em></p>
                }
            </div>
        </div>
    </div>

    <!-- CỘT PHẢI -->
    <div class="col-md-4">

        <div class="card mb-3 shadow-sm">
            <div class="card-header bg-light"><strong>Đơn vị tổ chức</strong></div>
            <div class="card-body">
                @if (toChuc != null)
                {
                    <p class="mb-1"><strong>@toChuc.TenToChuc</strong></p>
                    <p class="mb-1">Email: @toChuc.EmailLienHe</p>
                    <p class="mb-0 text-muted small">@toChuc.MoTa</p>
                }
                else
                {
                    <p class="text-muted"><em>Chưa có thông tin tổ chức.</em></p>
                }
            </div>
        </div>

        <!-- SỰ KIỆN TRỰC TUYẾN -->
        @if (loaiLower.Contains("trực tuyến") || loaiLower.Contains("online") || loaiLower.Contains("truc tuyen") || loaiLower.Contains("hybrid"))
        {
            <div class="card mb-3 shadow-sm">
                <div class="card-header bg-light"><strong>Sự kiện trực tuyến</strong></div>
                <div class="card-body">

                    @if (online != null)
                    {
                        <p class="mb-1"><strong>Nền tảng:</strong> @online.NenTang</p>

                        @if (laQuanTri || daMuaVe)
                        {
                            <p class="mb-1">
                                <strong>Link xem:</strong><br />
                                <a href="@online.LinkXem" target="_blank">@online.LinkXem</a>
                            </p>

                            @if (!string.IsNullOrWhiteSpace(online.HuongDan))
                            {
                                <p class="mb-0"><strong>Hướng dẫn:</strong><br />@online.HuongDan</p>
                            }
                        }
                        else
                        {
                            <p class="text-muted mb-2">
                                <em>Link xem sự kiện sẽ hiển thị sau khi bạn <strong>thanh toán vé thành công</strong>.</em>
                            </p>

                            @if (!(User?.Identity?.IsAuthenticated ?? false))
                            {
                                <p class="text-muted small mb-0">
                                    Vui lòng <a asp-controller="TaiKhoan" asp-action="DangNhap">đăng nhập</a>
                                    để đặt vé và nhận link tham gia sự kiện.
                                </p>
                            }
                        }
                    }
                    else
                    {
                        <p class="text-muted"><em>Chưa cấu hình thông tin trực tuyến.</em></p>
                    }
                </div>
            </div>
        }

        <a asp-action="DanhSach" class="btn btn-outline-secondary w-100">
            « Quay lại danh sách sự kiện
        </a>
    </div>
</div>
