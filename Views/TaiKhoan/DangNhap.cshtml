@model VeSuKienWeb.Models.TaiKhoan.DangNhapYeuCau
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="card shadow-sm mt-4">
            <div class="card-body">
                <h3 class="card-title text-center mb-3">Đăng nhập</h3>
                <p class="text-muted text-center mb-4">
                    Đăng nhập để bắt đầu đặt vé sự kiện.
                </p>

                <form asp-action="DangNhap" method="post">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email</label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MatKhau" class="form-label">Mật khẩu</label>
                        <input asp-for="MatKhau" type="password" class="form-control" />
                        <span asp-validation-for="MatKhau" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        Đăng nhập
                    </button>
                </form>

                <hr class="my-4" />

                <div class="text-center">
                    <span class="text-muted">Chưa có tài khoản?</span>
                    <a asp-controller="TaiKhoan" asp-action="DangKy">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>
