@model List<VeSuKienWeb.Models.SuKien>

@{
    ViewData["Title"] = "Trang chủ";
}

<partial name="_Banner" />

<!-- SỰ KIỆN NỔI BẬT -->
<section class="mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Sự kiện nổi bật</h3>
        <a asp-controller="SuKien" asp-action="DanhSach" class="text-decoration-none">
            Xem tất cả &raquo;
        </a>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var sk in Model)
            {
                <div class="col-md-4">
                    <div class="card event-card h-100 shadow-sm">

                        <img class="card-img-top"
                             src="@Url.Content(sk.AnhSuKien ?? "~/images/default-event.jpg")"
                             alt="@sk.TenSuKien"
                             style="height: 200px; object-fit: cover;" />

                        <div class="card-body">
                            <h5 class="card-title">@sk.TenSuKien</h5>

                            <p class="card-text text-muted small mb-1">
                                @sk.ThoiGianBatDau.ToString("HH:mm dd/MM/yyyy")
                            </p>

                            <p class="card-text small">
                                @(sk.MoTaChiTiet != null && sk.MoTaChiTiet.Length > 80
                                    ? sk.MoTaChiTiet.Substring(0, 80) + "..."
                                    : sk.MoTaChiTiet)
                            </p>

                            <a asp-controller="KhachHang"
                               asp-action="ChiTiet"
                               asp-route-id="@sk.SuKienId"
                               class="btn btn-outline-primary btn-sm">
                                Xem chi tiết
                            </a>
                        </div>

                    </div>
                </div>
            }
        }
        else
        {
            <p class="text-muted">Chưa có sự kiện nào được duyệt.</p>
        }
    </div>
</section>
